<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <amasty_companyaccount>
            <general>
                <inactivate_customer>1</inactivate_customer>
            </general>
            <admin_notif>
                <sender>general</sender>
                <receiver>general</receiver>
                <new_company_request>amasty_companyaccount_admin_notif_new_company_request</new_company_request>
                <new_company_create>amasty_companyaccount_admin_notif_new_company_create</new_company_create>
                <sales_representative_appointment>amasty_companyaccount_admin_notif_sales_representative_appointment</sales_representative_appointment>
            </admin_notif>
            <customer_notif>
                <sender>sales</sender>
                <active_status>amasty_companyaccount_customer_notif_active_status</active_status>
                <inactive_status>amasty_companyaccount_customer_notif_inactive_status</inactive_status>
                <rejected_status>amasty_companyaccount_customer_notif_rejected_status</rejected_status>
                <customer_linking>amasty_companyaccount_customer_notif_customer_linking</customer_linking>
                <customer_disable>amasty_companyaccount_customer_notif_customer_disable</customer_disable>
                <new_admin>amasty_companyaccount_customer_notif_new_admin</new_admin>
                <admin_unassign>amasty_companyaccount_customer_notif_admin_unassign</admin_unassign>
            </customer_notif>
        </amasty_companyaccount>
    </default>
</config>
